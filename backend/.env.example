# ---- Server ----
PORT=5000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change_me_to_something_secret

# ---- MongoDB ----
# If omitted, the server runs in IN-MEMORY mode (no persistence) so the demo
# still works without a local Mongo install.
MONGODB_URI=mongodb://localhost:27017/citemind

# ---- Groq (LLM) ----
# Free key from https://console.groq.com
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=openai/gpt-oss-120b

# ---- Hindsight (memory) ----
# Cloud: https://ui.hindsight.vectorize.io  (promo MEMHACK6 for $50 credits)
# Or run locally and point at http://localhost:8888
# If these are omitted, CiteMind uses a built-in Groq-backed memory engine so
# the demo (retain / observations / reflect) still works end to end.
HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io
HINDSIGHT_API_KEY=
